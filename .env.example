# =========================
# Notion 内容同步
# =========================
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =========================
# 博客公开信息
# 这些变量会在构建时注入站点
# =========================
PUBLIC_BLOG_TITLE=我的博客
PUBLIC_BLOG_SUBTITLE=在 Notion 写作，用 Astro 发布
PUBLIC_BLOG_DESCRIPTION=在 Notion 中管理内容，并发布到 GitHub Pages。
PUBLIC_BLOG_AUTHOR=你的名字
PUBLIC_BLOG_MOTTO=记录思考、技术与生活。
PUBLIC_BLOG_GITHUB=https://github.com/your-name
PUBLIC_BLOG_PROFILE=https://your-site.example.com/
PUBLIC_BLOG_AVATAR=/img/starter-avatar.svg
PUBLIC_BLOG_LOGO=/img/starter-logo.svg
PUBLIC_BLOG_DEFAULT_COVER=/img/starter-cover.svg
PUBLIC_BLOG_RUNTIME_SINCE=2024-01-01
PUBLIC_BLOG_RECORD_TEXT=
PUBLIC_BLOG_RECORD_LINK=

# =========================
# 站点部署
# =========================
SITE_URL=https://your-user.github.io
BASE_PATH=/your-repo
PAGES_TARGET_REPOSITORY=your-name/your-pages-repo
PAGES_TARGET_BRANCH=gh-pages
SITE_CNAME=

# =========================
# Cloudflare Worker 本地部署
# 仅在本地使用 wrangler deploy / wrangler dev 时需要
# =========================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# =========================
# Notion Webhook Relay 参考变量
# 这些变量主要给 automation/notion-webhook-relay 使用
# 也可以单独写到该目录下的 .env 中
# =========================
GITHUB_OWNER=your-github-username
GITHUB_REPO=notion-astro-blog
NOTION_WEBHOOK_EVENT_TYPE=notion-content-updated

# =========================
# Worker Secrets
# 不建议直接写入 .env，通常使用 wrangler secret put 设置
# =========================
# GITHUB_DISPATCH_TOKEN=
# NOTION_WEBHOOK_VERIFICATION_TOKEN=
