# Notion
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Blog public settings
PUBLIC_BLOG_TITLE=My Blog
PUBLIC_BLOG_SUBTITLE=New Beginning, New Way
PUBLIC_BLOG_DESCRIPTION=Notes on tech, projects, and life.
PUBLIC_BLOG_AUTHOR=Your Name
PUBLIC_BLOG_MOTTO=Build slowly, think clearly.
PUBLIC_BLOG_GITHUB=https://github.com/your-name
PUBLIC_BLOG_PROFILE=https://your-site.example.com/
PUBLIC_BLOG_AVATAR=/img/starter-avatar.svg
PUBLIC_BLOG_LOGO=/img/starter-logo.svg
PUBLIC_BLOG_DEFAULT_COVER=/img/starter-cover.svg
PUBLIC_BLOG_RUNTIME_SINCE=2024-01-01
PUBLIC_BLOG_RECORD_TEXT=
PUBLIC_BLOG_RECORD_LINK=

# Template system
# Presets: classic | ledger | essay | clover | pulse
# Legacy aliases still supported: horizon | paper | graphite
PUBLIC_TEMPLATE_PRESET=classic

# Layouts: showcase | journal | focus
# If omitted, the preset default will be used.
PUBLIC_HOME_TEMPLATE=

# Card styles: magazine | compact | outline
PUBLIC_CARD_STYLE=

# Sidebar styles: stacked | minimal
PUBLIC_SIDEBAR_STYLE=

# Optional custom theme overrides
PUBLIC_THEME_COLOR=
PUBLIC_THEME_COLOR_DEEP=
PUBLIC_THEME_ACCENT=
PUBLIC_THEME_TEXT=
PUBLIC_THEME_MUTED=
PUBLIC_THEME_LINE=
PUBLIC_THEME_BG=
PUBLIC_THEME_PANEL=
PUBLIC_THEME_PANEL_SOLID=
PUBLIC_THEME_PANEL_SOFT=
PUBLIC_THEME_SHADOW=
PUBLIC_THEME_SHADOW_STRONG=
PUBLIC_THEME_BG_IMAGE=
PUBLIC_THEME_NAV_BG=
PUBLIC_THEME_NAV_BORDER=
PUBLIC_THEME_HERO_MASK=
PUBLIC_THEME_HERO_PANEL_BG=
PUBLIC_THEME_HERO_PANEL_BORDER=
PUBLIC_THEME_HERO_PANEL_SHADOW=
PUBLIC_THEME_SOFT_FILL=
PUBLIC_THEME_SOFT_FILL_STRONG=
PUBLIC_THEME_CODE_BG=
PUBLIC_THEME_CODE_TEXT=
PUBLIC_THEME_READING_TEXT=
PUBLIC_THEME_RADIUS_LG=
PUBLIC_THEME_RADIUS_MD=
PUBLIC_THEME_RADIUS_SM=
PUBLIC_THEME_NAV_WIDTH=
PUBLIC_THEME_CONTENT_WIDTH=
PUBLIC_THEME_PAGE_WIDTH=
PUBLIC_THEME_READING_WIDTH=
PUBLIC_THEME_FONT_SANS=
PUBLIC_THEME_FONT_DISPLAY=

# Deploy
SITE_URL=https://your-user.github.io
BASE_PATH=/your-repo
PAGES_TARGET_REPOSITORY=your-name/your-pages-repo
PAGES_TARGET_BRANCH=gh-pages
SITE_CNAME=

# Cloudflare Workers
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
