---
import { formatDate, getDefaultCover, slugifyCategory, slugifyTag } from "../lib/posts";

interface Props {
  post: any;
  variant?: "feature" | "grid" | "compact";
  postBasePath?: string;
}

const { post, variant = "grid", postBasePath = "posts" } = Astro.props;
const previewTags = post.tags.slice(0, variant === "feature" ? 4 : variant === "compact" ? 1 : 2);
const previewCategories = post.categories.slice(0, variant === "feature" ? 2 : 1);
const normalizedBasePath = postBasePath.replace(/^\/+|\/+$/g, "");
const postHref = `${import.meta.env.BASE_URL}${normalizedBasePath}/${post.slug}/`;
---

<article class:list={["post-card", `post-card-${variant}`]}>
  <a class="post-card-cover" href={postHref} title={post.title}>
    <img class="post-card-image" src={getDefaultCover(post)} alt={post.title} loading="lazy" />
  </a>

  <div class="post-card-body">
    <div class="post-card-meta">
      <span>发布于 {formatDate(post.publishedAt)}</span>
      <span>阅读 {post.readingMinutes} 分钟</span>
    </div>

    <a class="post-card-title" href={postHref} title={post.title}>{post.title}</a>

    {previewCategories.length > 0 && (
      <div class="post-card-categories">
        {previewCategories.map((category: string) => (
          <a class="post-card-category" href={`${import.meta.env.BASE_URL}categories/${slugifyCategory(category)}/`}>
            {category}
          </a>
        ))}
      </div>
    )}

    <p class="post-card-summary">{post.summary}</p>

    <div class="post-card-footer">
      <div class="post-card-tags">
        {previewTags.map((tag: string) => (
          <a href={`${import.meta.env.BASE_URL}tags/${slugifyTag(tag)}/`}>#{tag}</a>
        ))}
      </div>
      <a class="post-card-link" href={postHref}>继续阅读</a>
    </div>
  </div>
</article>
