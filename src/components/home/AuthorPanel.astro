---
import { getAllCategories, getAllPosts, getAllTags } from "../../lib/posts";
import { siteConfig } from "../../lib/site";

interface Props {
  title?: string;
  variant?: "card" | "minimal";
}

const { title = siteConfig.author, variant = "card" } = Astro.props;
const posts = getAllPosts();
const tags = getAllTags();
const categories = getAllCategories();
---

<section class:list={["sidebar-card", "author-card", `author-card-${variant}`]}>
  <div class="author-card-top">
    <img src={siteConfig.avatar} alt={siteConfig.author} />
    <div>
      <h3>{title}</h3>
      <p>{siteConfig.motto}</p>
    </div>
  </div>

  <div class="author-stats">
    <a href={`${import.meta.env.BASE_URL}archive/`}>
      <strong>{posts.length}</strong>
      <span>文章</span>
    </a>
    <a href={`${import.meta.env.BASE_URL}tags/`}>
      <strong>{tags.length}</strong>
      <span>标签</span>
    </a>
    <a href={`${import.meta.env.BASE_URL}categories/`}>
      <strong>{categories.length}</strong>
      <span>分类</span>
    </a>
  </div>
</section>
