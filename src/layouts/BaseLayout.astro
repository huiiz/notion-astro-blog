---
import "../styles/global.css";
import { notionNavigation, type NavigationItem } from "../lib/notion-config";
import { withBasePath } from "../lib/paths";
import { siteConfig } from "../lib/site";
import { themeConfig, type ThemeConfig } from "../lib/theme";

interface Props {
  title?: string;
  description?: string;
  theme?: ThemeConfig;
}

const { title, description, theme } = Astro.props;
const activeTheme = theme || themeConfig;
const pageTitle = title ? `${title} | ${siteConfig.title}` : `${siteConfig.title} - ${siteConfig.subtitle}`;
const pageDescription = description || siteConfig.description;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://example.com");
const currentYear = new Date().getFullYear();
const nav = notionNavigation.length ? notionNavigation : buildDefaultNavigation();

function buildDefaultNavigation(): NavigationItem[] {
  const items: NavigationItem[] = [
    { href: "/", label: "\u9996\u9875" },
    { href: "/archive/", label: "\u5f52\u6863" },
    { href: "/tags/", label: "\u6807\u7b7e" },
    { href: "/categories/", label: "\u5206\u7c7b" },
    { href: "/link/", label: "\u53cb\u94fe" },
    { href: "/about/", label: "\u5173\u4e8e" }
  ];

  if (siteConfig.profile) {
    items.push({ href: siteConfig.profile, label: "\u4e2a\u4eba\u4e3b\u9875", external: true });
  }

  return items;
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0,viewport-fit=cover" />
    <title>{pageTitle}</title>
    <meta name="author" content={siteConfig.author} />
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={new URL(siteConfig.avatar, Astro.site ?? "https://example.com").toString()} />
    <meta name="twitter:card" content="summary" />
    <meta name="theme-color" content={activeTheme.themeColor} />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="shortcut icon" href={siteConfig.logo} />
    <link rel="alternate" type="application/rss+xml" title={siteConfig.title} href={`${import.meta.env.BASE_URL}rss.xml`} />
    <script is:inline>
      window.MathJax = {
        tex: {
          inlineMath: [["$", "$"], ["\\(", "\\)"]],
          displayMath: [["$$", "$$"], ["\\[", "\\]"]],
          processEscapes: true
        },
        options: {
          skipHtmlTags: ["script", "noscript", "style", "textarea", "pre", "code"]
        }
      };
    </script>
    <script
      is:inline
      async
      id="mathjax-script"
      src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"
    ></script>
  </head>
  <body>
    <div
      class="page"
      id="body-wrap"
      data-theme-preset={activeTheme.preset}
      data-home-template={activeTheme.homeTemplate}
      data-card-style={activeTheme.cardStyle}
      data-sidebar-style={activeTheme.sidebarStyle}
      style={activeTheme.inlineStyle}
    >
      <nav id="nav">
        <div class="nav-inner">
          <a class="nav-site-title" href={import.meta.env.BASE_URL}>
            <img class="site-icon" src={siteConfig.logo} alt="Logo" />
            <span class="site-branding">
              <strong class="site-name">{siteConfig.title}</strong>
              <small>{siteConfig.subtitle}</small>
            </span>
          </a>

          <div id="menus">
            <div class="menus-items">
              {nav.map((item) => (
                <div class="menus-item">
                  <a
                    class="site-page"
                    href={item.external ? item.href : withBasePath(item.href)}
                    target={item.external ? "_blank" : undefined}
                    rel={item.external ? "noreferrer" : undefined}
                  >
                    <span>{item.label}</span>
                  </a>
                </div>
              ))}
            </div>
          </div>
        </div>
      </nav>

      <slot />

      <footer id="footer">
        <div class="footer-inner">
          <div class="footer-other">
            <div class="footer-copyright">
              <span class="copyright">&copy; {currentYear} By {siteConfig.author}</span>
            </div>
            {siteConfig.recordText && siteConfig.recordLink && (
              <div class="footer-custom-text">
                <span><a href={siteConfig.recordLink} target="_blank" rel="noreferrer">{siteConfig.recordText}</a></span>
              </div>
            )}
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
