---
import PageHeader from "../components/PageHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="页面不存在">
  <PageHeader title="页面不存在" subtitle="你访问的页面不存在，或者已经被移动到了新的位置。" />
  <main class="layout layout-page" id="content-inner">
    <article id="page">
      <div class="post-content">
        <p>可以先回到首页，或者去归档页继续浏览。</p>
        <p>
          <a href={`${import.meta.env.BASE_URL}`}>返回首页</a>
          {" · "}
          <a href={`${import.meta.env.BASE_URL}archive/`}>查看归档</a>
        </p>
      </div>
    </article>
  </main>
</BaseLayout>
