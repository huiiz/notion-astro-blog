---
import PageHeader from "../../components/PageHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getArchiveGroups, getDefaultCover } from "../../lib/posts";

const groups = getArchiveGroups();
const total = groups.reduce((count, group) => count + group.posts.length, 0);
---

<BaseLayout title="文章归档">
  <PageHeader title="文章归档" subtitle="按时间线回看这些年写下的内容，保留每一次主题转向和阶段记录。" />
  <main class="layout layout-page" id="content-inner">
    <div id="archive">
      <div class="article-sort-title">全部文章 · {total}</div>
      <div class="article-sort">
        {groups.map((group) => (
          <>
            <div class="article-sort-item year">{group.year}</div>
            {group.posts.map((post) => (
              <div class="article-sort-item">
                <a class="article-sort-item-img" href={`${import.meta.env.BASE_URL}posts/${post.slug}/`} title={post.title}>
                  <img src={getDefaultCover(post)} alt={post.title} loading="lazy" />
                </a>
                <div class="article-sort-item-info">
                  <div class="article-sort-item-time">
                    <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>
                  </div>
                  <a class="article-sort-item-title" href={`${import.meta.env.BASE_URL}posts/${post.slug}/`} title={post.title}>
                    {post.title}
                  </a>
                </div>
              </div>
            ))}
          </>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
