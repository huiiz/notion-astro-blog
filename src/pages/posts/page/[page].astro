---
import Pagination from "../../../components/Pagination.astro";
import PostCard from "../../../components/PostCard.astro";
import PageHeader from "../../../components/PageHeader.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { POSTS_PAGE_SIZE, buildStaticPaginationPaths, paginateItems } from "../../../lib/pagination";
import { getAllPosts } from "../../../lib/posts";

const allPosts = getAllPosts();

export function getStaticPaths() {
  return buildStaticPaginationPaths(getAllPosts().length, POSTS_PAGE_SIZE);
}

const currentPage = Number(Astro.params.page || "1");
const pagination = paginateItems(allPosts, currentPage, POSTS_PAGE_SIZE);
---

<BaseLayout title={`全部文章 · 第 ${pagination.currentPage} 页`}>
  <PageHeader title={`全部文章 · 第 ${pagination.currentPage} 页`} subtitle="继续按时间顺序浏览所有文章。" />
  <main class="layout layout-page" id="content-inner">
    <div class="home-grid page-grid">
      {pagination.items.map((post, index) => (
        <PostCard post={post} variant={index === 0 ? "feature" : "grid"} />
      ))}
    </div>
    <Pagination currentPage={pagination.currentPage} totalPages={pagination.totalPages} kind="posts" />
  </main>
</BaseLayout>
