---
import PageHeader from "../../components/PageHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getTagCounts, slugifyTag } from "../../lib/posts";

const tags = getTagCounts();
---

<BaseLayout title="标签">
  <PageHeader title="标签" subtitle="从主题切入，找到你更想继续往下读的一组内容和相近问题。" />
  <main class="layout layout-page" id="content-inner">
    <div class="tag-cloud-card">
      <div class="home-section-title cloud-title">
        <div>
          <span class="section-kicker">标签目录</span>
          <h2>全部标签</h2>
        </div>
      </div>
      <div class="tag-cloud-grid">
        {tags.map((item) => (
          <a href={`${import.meta.env.BASE_URL}tags/${slugifyTag(item.name)}/`}>
            <span>{item.name}</span>
            <small>{item.count}</small>
          </a>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
